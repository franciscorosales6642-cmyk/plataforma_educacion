<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:label="Plataforma Educativa"
        android:supportsRtl="true"
        android:theme="@style/Theme.PlataformaEducacion"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".RegisterActivity" android:exported="false" />
        <activity android:name=".MainActivity" android:exported="false" />
        <activity android:name=".CursosActivity" android:exported="false" />
        <activity android:name=".DetalleCursoActivity" android:exported="false" />
        <activity android:name=".PerfilActivity" android:exported="false" />
        <activity android:name=".CalificarCursoActivity" android:exported="false" />
        <activity android:name=".CertificadoActivity" android:exported="false" />
    </application>

</manifest>
